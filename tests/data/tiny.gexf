<?xml version="1.0" encoding="UTF-8"?>
<gexf xmlns="http://www.gexf.net/1.3" version="1.3">
  <graph mode="static" defaultedgetype="undirected">
    <nodes>
      <node id="a" label="A" />
      <node id="b" label="B" />
      <node id="c" label="C" />
    </nodes>
    <edges>
      <edge id="0" source="a" target="b" />
      <edge id="1" source="b" target="c" />
    </edges>
  </graph>
</gexf>
